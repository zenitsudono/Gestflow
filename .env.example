# Django Configuration
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-!gestiflow!
ALLOWED_HOSTS=localhost,127.0.0.1,web

# PostgreSQL Configuration
DB_NAME=gestiflow_db
DB_USER=gestiflow_user
DB_PASSWORD=gestiflow_pass
DB_HOST=db
DB_PORT=5432

# Redis & Celery Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email Configuration
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=your_smtp_user
EMAIL_HOST_PASSWORD=your_smtp_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@gestiflow.com

# AWS S3 Storage (Optional for Dev, Required for Prod)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=gestiflow-storage
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=

# Sentry Monitoring (Production)
SENTRY_DSN=
